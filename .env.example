# ─────────────────────────────────────────────────────────────────────────────
# Spotify OAuth 2.0 + PKCE — React App credentials
# ─────────────────────────────────────────────────────────────────────────────
#
# Steps to get your credentials:
#   1. Go to https://developer.spotify.com/dashboard
#   2. Log in → click "Create app"
#   3. Fill in App name (e.g. "MusicApp") and description
#   4. Under "Redirect URIs" add:  http://127.0.0.1:3000/callback
#   5. Check "Web API" under "Which API/SDKs are you planning to use?"
#   6. Save → copy Client ID from the app dashboard
#
# NOTE: Client Secret is NOT required for PKCE (no secret in the frontend).
#
# Rename this file to .env (it is already in .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# Your Spotify app Client ID (from the dashboard — safe to expose)
REACT_APP_SPOTIFY_CLIENT_ID=your_client_id_here

# Redirect URI registered in your Spotify dashboard
# Must match EXACTLY (including the trailing path) — change only if you deploy
REACT_APP_SPOTIFY_REDIRECT_URI=http://localhost:3000/callback

# ─────────────────────────────────────────────────────────────────────────────
# Supabase — playlist storage
# ─────────────────────────────────────────────────────────────────────────────
#
# Steps to get your credentials:
#   1. Go to https://supabase.com/dashboard and open your project
#   2. Navigate to Settings → API
#   3. Copy "Project URL" and "anon public" key below
#
REACT_APP_SUPABASE_URL=https://your-project-id.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key-here
